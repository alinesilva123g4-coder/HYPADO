# =============================================================================
# HYPADO · variáveis de ambiente
# Copie para .env (dev) e configure as mesmas chaves na Netlify (produção).
# =============================================================================

# --- Site --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://hypado.site
NEXT_PUBLIC_BRAND=HYPADO

# --- Banco (Supabase Postgres) ----------------------------------------------
# DATABASE_URL: pooler (porta 6543) — runtime serverless.
# DIRECT_URL:   conexão direta (porta 5432) — migrations.
# connection_limit alto (>1) é necessário: o dashboard admin dispara ~26 queries
# em paralelo; com limit=1 elas enfileiram e estouram o pool_timeout (erro P2024).
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=20
DIRECT_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- Supabase JS / Storage --------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_UPLOAD_BUCKET=hypado-uploads

# --- WhatsApp / Instagram ---------------------------------------------------
# Número internacional sem +. Ex.: 5581999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=5500000000000
WHATSAPP_NUMBER=5500000000000
NEXT_PUBLIC_INSTAGRAM=hypado

# --- Chatbot (Heitor) — OpenAI-compat (Groq por padrão) ---------------------
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=

# --- Analytics (preencha depois de criar Pixel e GA4) -----------------------
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_ID=

# --- Meta Conversions API (server-side, opcional) ---------------------------
# Pixel server-side com deduplicação. Pegue o token em:
#   Gerenciador de Eventos → seu Pixel → Configurações → Token de acesso da CAPI.
# META_PIXEL_ID normalmente é o mesmo número do NEXT_PUBLIC_META_PIXEL_ID.
# META_TEST_EVENT_CODE só para teste (Test Events) — deixe vazio em produção.
META_PIXEL_ID=
META_CAPI_TOKEN=
META_TEST_EVENT_CODE=
